# =============================================
# AssemblEat — Supabase Platform Environment
# =============================================
# Copy to .env and fill in all values before deploying.
# NEVER commit .env to version control.

# ---------------------------
# PostgreSQL
# ---------------------------
POSTGRES_PASSWORD=change-me-min-32-chars

# ---------------------------
# JWT
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# ---------------------------
JWT_SECRET=change-me-min-32-chars-for-jwt

# Generate ANON_KEY and SERVICE_ROLE_KEY using your JWT_SECRET.
# Use: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# or:  node -e "const j=require('jsonwebtoken'); console.log(j.sign({role:'anon'},process.env.JWT_SECRET,{expiresIn:'10y'}))"
ANON_KEY=generate-with-jwt-secret
SERVICE_ROLE_KEY=generate-with-jwt-secret

# ---------------------------
# URLs
# ---------------------------
SITE_URL=https://assembleat.app
API_EXTERNAL_URL=https://api.assembleat.app

# ---------------------------
# Google OAuth (optional)
# Create credentials at https://console.cloud.google.com
# Redirect URI: https://api.assembleat.app/auth/v1/callback
# ---------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------
# SMTP (email)
# ---------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_EMAIL=noreply@assembleat.app
